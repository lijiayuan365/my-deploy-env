TZ=Asia/Shanghai
GITLAB_RUNNER_IMAGE=gitlab/gitlab-runner:alpine
CI_SERVER_URL=https://gitlab.example.com
RUNNER_CLONE_URL=
RUNNER_NAME=my-docker-runner
RUNNER_EXECUTOR=docker
RUNNER_DOCKER_IMAGE=alpine:3.20

# Recommended: runner authentication token created in GitLab UI/API.
# Typical prefix: glrt-
RUNNER_TOKEN=

# Optional legacy registration token. Deprecated by GitLab and planned for
# removal in GitLab 20.0. Only use it if your GitLab instance still requires it.
RUNNER_REGISTRATION_TOKEN=

# The following options are only used with RUNNER_REGISTRATION_TOKEN.
RUNNER_TAG_LIST=docker
RUNNER_RUN_UNTAGGED=true
RUNNER_LOCKED=false
RUNNER_ACCESS_LEVEL=not_protected
